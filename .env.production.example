# Paylo — Production Environment Template
# ----------------------------------------------------------------------------
# Bu faylı .env-ə kopyalayıb dəyərləri doldur. Heç bir dəyər `null`, `null` və
# ya boş qalmamalıdır. APP_KEY-i `php artisan key:generate` ilə yarat.
# ----------------------------------------------------------------------------

# Tətbiq
APP_NAME="Paylo"
APP_ENV=production
APP_KEY=                                          # `php artisan key:generate` icra et
APP_DEBUG=false                                   # PRODUCTION-DA HƏMİŞƏ false
APP_URL=https://app.paylo.az                      # HTTPS məcburi — AppServiceProvider URL::forceScheme
APP_LOCALE=az
APP_FALLBACK_LOCALE=en
APP_TIMEZONE=Asia/Baku

# Reverse proxy (Nginx). `*` development üçün; production-da konkret IP siyahısı:
# məsələn `127.0.0.1,10.0.0.0/8` (Cloudflare arxasındasansa Cloudflare IP range-i).
TRUSTED_PROXIES=127.0.0.1

# Logging
LOG_CHANNEL=stack
LOG_LEVEL=warning                                 # Production: warning və ya error

# Database (MySQL 8+ InnoDB; ledger immutability InnoDB row-locking tələb edir)
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=paylo
DB_USERNAME=paylo_app
DB_PASSWORD=                                      # CHANGE ME — uzun random parol

# Redis (cache, session, queue üçün vahid instance)
REDIS_CLIENT=predis                               # predis/predis composer paketi quraşdırıldı
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=                                   # Redis ACL ilə təyin et; null deyil
REDIS_PREFIX=paylo_

# Cache, Session, Queue → hamısı Redis
CACHE_STORE=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_SECURE_COOKIE=true                        # HTTPS-only cookie
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax
QUEUE_CONNECTION=redis

# Broadcasting
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# CORS — mobil app və web origin-ləri
CORS_ALLOWED_ORIGINS=https://app.paylo.az,https://admin.paylo.az

# Sanctum SPA (web Inertia) üçün cookie domain
SANCTUM_STATEFUL_DOMAINS=app.paylo.az,admin.paylo.az
SESSION_DOMAIN=.paylo.az

# Mail (backup notification, error alerts üçün)
MAIL_MAILER=smtp
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="no-reply@paylo.az"
MAIL_FROM_NAME="${APP_NAME}"

# Sentry — error tracking
SENTRY_LARAVEL_DSN=                               # https://xxxxx@oXXXX.ingest.sentry.io/XXXX
SENTRY_TRACES_SAMPLE_RATE=0.1                     # 10% transaction tracing
SENTRY_PROFILES_SAMPLE_RATE=0.0                   # 0 = profiling off (cost)
SENTRY_SEND_DEFAULT_PII=false                     # GDPR: PII göndərmə

# Backup (spatie/laravel-backup)
BACKUP_DISKS=local                                # Production üçün `s3,local` tövsiyə olunur
BACKUP_ARCHIVE_PASSWORD=                          # Zip encryption parolu (uzun random)
BACKUP_NOTIFICATION_EMAIL=admin@paylo.az          # Failure/health notification ünvanı

# (Opsional) S3 backup destination — filesystems.php-da s3 disk təyin olunmalıdır
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=eu-central-1
# AWS_BUCKET=paylo-backup-prod

# Vite asset URL-i (CDN istifadə olunursa)
VITE_APP_NAME="${APP_NAME}"
